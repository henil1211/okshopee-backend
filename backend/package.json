{
  "name": "matrixmlm-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "test": "node --test tests/**/*.test.js",
    "check": "node --check server.js",
    "verify:wallet:file": "node scripts/verify-wallet-ledger-resync.cjs",
    "verify:wallet:mysql": "node scripts/verify-wallet-ledger-resync.cjs --mysql",
    "verify:wallet:gate:file": "node scripts/verify-wallet-ledger-resync.cjs --fail-on-mismatch",
    "verify:wallet:gate:mysql": "node scripts/verify-wallet-ledger-resync.cjs --mysql --fail-on-mismatch",
    "audit:pin-integrity:dry": "node scripts/audit-v2-pin-purchase-integrity.cjs",
    "audit:pin-integrity:apply": "node scripts/audit-v2-pin-purchase-integrity.cjs --apply",
    "repair:pin-format:dry": "node scripts/repair-v2-pin-code-format.cjs",
    "repair:pin-format:apply": "node scripts/repair-v2-pin-code-format.cjs --apply",
    "cleanup:legacy-wallet-smoke:dry": "node scripts/fix-legacy-wallet-gaps-and-smoke-users.cjs",
    "cleanup:legacy-wallet-smoke:apply": "node scripts/fix-legacy-wallet-gaps-and-smoke-users.cjs --apply",
    "backfill:pins:legacy-to-v2:dry": "node scripts/backfill-legacy-pins-to-v2.cjs",
    "backfill:pins:legacy-to-v2:apply": "node scripts/backfill-legacy-pins-to-v2.cjs --apply",
    "audit:registration-integrity:dry": "node scripts/audit-registration-integrity.cjs",
    "recover:registration:user:dry": "node scripts/recover-v2-user-registration.cjs --user-code 0000000",
    "recover:registration:user:apply": "node scripts/recover-v2-user-registration.cjs --apply --user-code 0000000",
    "v2:smoke:inputs": "node scripts/get-v2-smoke-inputs.cjs",
    "phasea:fix:dry": "node scripts/fix-v2-phase-a-seeding.cjs",
    "phasea:fix:apply": "node scripts/fix-v2-phase-a-seeding.cjs --apply",
    "v2:close-fake-users": "node scripts/close-v2-users.cjs 2000002 3000003 --status closed",
    "v2:smoke:provision-dummies": "node scripts/provision-v2-help-smoke-dummies.js",
    "v2:smoke:help-phase3": "node scripts/smoke-test-v2-help-phase3.js",
    "v2:requeue:missing-reg-help:dry": "node scripts/requeue-missing-v2-registration-help.js --all-missing",
    "v2:requeue:missing-reg-help:apply": "node scripts/requeue-missing-v2-registration-help.js --all-missing --apply",
    "v2:audit:help-gaps": "node scripts/audit-v2-help-gaps.js",
    "v2:audit:help-gaps:json": "node scripts/audit-v2-help-gaps.js --json",
    "v2:repair:immediate-give-help:dry": "node scripts/repair-v2-immediate-give-help.js --dry-run --source-user-code 0000000",
    "v2:repair:immediate-give-help:apply": "node scripts/repair-v2-immediate-give-help.js --apply --source-user-code 0000000",
    "legacy:repair:help-overcredit:dry": "node scripts/repair-legacy-help-overcredit-by-users.cjs --users 0000000 --dry-run",
    "legacy:repair:help-overcredit:apply": "node scripts/repair-legacy-help-overcredit-by-users.cjs --users 0000000 --apply",
    "legacy:audit:all-financial-issues": "node scripts/audit-legacy-all-financial-issues.cjs",
    "legacy:audit:all-financial-issues:json": "node scripts/audit-legacy-all-financial-issues.cjs --json"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "mysql2": "^3.12.0",
    "nodemailer": "^8.0.1"
  }
